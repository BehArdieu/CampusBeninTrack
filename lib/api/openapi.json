                  "images": {
                    "type": [
                      "array",
                      "null"
                    ],
                    "items": {
                      "type": "string",
                      "format": "binary",
                      "contentMediaType": "application/octet-stream",
                      "maxLength": 5120
                    }
                  }
                },
                "required": [
                  "annonce_id",
                  "address",
                  "prix"
                ]
