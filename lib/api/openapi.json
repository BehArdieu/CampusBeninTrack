  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Positionnement": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "annonce_id": {
            "type": "integer"
          },
          "diaspora_id": {
            "type": "integer"
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/PositionnementStatus"
          },
          "read_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "created_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "updated_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "annonce_id",
          "diaspora_id",
          "message",
          "status",
          "read_at",
          "created_at",
          "updated_at"
        ],
        "title": "Positionnement"
      },
      "PositionnementStatus": {
        "type": "string",
        "description": "| |\n|---|\n| `en_attente` <br/> En attente de réponse de l'étudiant |\n| `lu` <br/> Visualisée par l'étudiant |\n| `accepte` <br/> Acceptée, la diaspora aidera l'étudiant |\n| `refuse` <br/> Refusée par l'étudiant |",
        "enum": [
          "en_attente",
          "lu",
          "accepte",
          "refuse"
        ],
        "title": "PositionnementStatus"
      },
      "Reponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "annonce_id": {
            "type": "integer"
          },
          "diaspora_id": {
            "type": "integer"
          },
          "address": {
            "type": "string"
          },
          "prix": {
            "type": "number"
