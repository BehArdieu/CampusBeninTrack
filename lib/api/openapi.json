{
  "openapi": "3.1.0",
  "info": {
    "title": "CampusBeninTrack API",
    "version": "1.0.0",
    "description": "Plateforme de mise en relation entre étudiants africains et membres de la diaspora pour la recherche de logement en France."
  },
  "servers": [
    {
      "url": "https://360campusfrance.mega-devs.com/api"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/annonces": {
      "get": {
        "operationId": "annonces.index",
        "description": "Authenticated diaspora members see all requests; students see only their own.",
        "summary": "List all housing requests",
        "tags": [
          "Annonces"
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "const": 200
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/AuthenticationException"
          }
        }
      },
      "post": {
        "operationId": "annonces.store",
        "summary": "Create a new housing request",
        "tags": [
          "Annonces"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titre": {
                    "type": "string",
                    "maxLength": 255
                  },
                  "description": {
                    "type": "string"
                  },
                  "photo": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "universite": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "ville_id": {
                    "type": "integer"
                  }
                },
                "required": [
                  "titre",
                  "description",
                  "ville_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "const": 201
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/AuthenticationException"
          },
          "422": {
            "$ref": "#/components/responses/ValidationException"
          }
        }
      }
    },
